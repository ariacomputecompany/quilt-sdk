{
  "name": "quilt-sdk",
  "version": "0.0.8",
  "description": "Fully type-safe TypeScript SDK for Quilt HTTP APIs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "quilt": "./dist/cli.js",
    "quilt-sdk": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "clean": "rm -rf dist coverage .tsbuildinfo generated",
    "generate:types": "node ./scripts/generate-contract-types.mjs",
    "build": "npm run generate:types && tsc -p tsconfig.build.json && node ./scripts/fix-esm-imports.mjs",
    "typecheck": "npm run generate:types && tsc -p tsconfig.json --noEmit",
    "examples:typecheck": "tsc -p tsconfig.examples.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "${BUN_BIN:-$HOME/.bun/bin/bun} test",
    "test:coverage": "${BUN_BIN:-$HOME/.bun/bin/bun} test --coverage",
    "examples:all": "npm run example:containers && npm run example:images && npm run example:sdk && npm run example:clusters && npm run example:terminal && npm run example:elasticity && npm run example:lifecycle",
    "example:containers": "node --env-file=.env --import tsx examples/containers-volumes-and-network.ts",
    "example:images": "node --env-file=.env --import tsx examples/docker-and-oci-images.ts",
    "example:sdk": "node --env-file=.env --import tsx examples/sdk-runtime-and-functions.ts",
    "example:clusters": "node --env-file=.env --import tsx examples/clusters-nodes-workloads-and-k8s.ts",
    "example:terminal": "node --env-file=.env --import tsx examples/terminal-and-icc.ts",
    "example:elasticity": "node --env-file=.env --import tsx examples/elasticity-control.ts",
    "example:lifecycle": "node --env-file=.env --import tsx examples/lifecycle-and-failures.ts",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm run examples:typecheck && npm run test && npm run build"
  },
  "keywords": ["quilt", "sdk", "api", "typescript", "bun"],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.0",
    "eventsource": "^3.0.7",
    "openapi-typescript": "^7.6.1",
    "protobufjs": "^8.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "tar": "^7.4.3"
  }
}
